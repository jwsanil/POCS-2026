7. Database Config Changes

# Database configuration for PostgreSQL

DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sample
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=admin
DATABASE_SSL=false
DATABASE_SCHEMA=public
#JWT_SECRET=pWVGZSGapvQpgKJWAW2xJg==

8. Install PostgreSQL Driver

npm install pg

9. Restart Strapi

npm run develop

PS D:\github-new\POCS-2026\EC-DATA-Container-new-relic-demo-strapi-cms> npm run develop

10. Hibernate Entity Change (if Hibernate used)

@ManyToOne
@JoinTable(
name = "customers_employee_lnk",
joinColumns = @JoinColumn(name = "customer_id"),
inverseJoinColumns = @JoinColumn(name = "employee_id")
)
private Employee employee;

11. Full Customer Entity Example

package org.example.entity;

import jakarta.persistence.*;

@Entity
@Table(name = "customers")
public class Customer {

```
@Id
private Long id;

private Integer customerid;
private String firstname;
private String lastname;
private String email;
private String phone;

@ManyToOne
@JoinTable(
    name = "customers_employee_lnk",
    joinColumns = @JoinColumn(name = "customer_id"),
    inverseJoinColumns = @JoinColumn(name = "employee_id")
)
private Employee employee;

public Customer() {
}

public Long getId() {
    return id;
}

public Integer getCustomerid() {
    return customerid;
}

public void setCustomerid(Integer customerid) {
    this.customerid = customerid;
}

public String getFirstname() {
    return firstname;
}

public void setFirstname(String firstname) {
    this.firstname = firstname;
}

public String getLastname() {
    return lastname;
}

public void setLastname(String lastname) {
    this.lastname = lastname;
}

public String getEmail() {
    return email;
}

public void setEmail(String email) {
    this.email = email;
}

public String getPhone() {
    return phone;
}

public void setPhone(String phone) {
    this.phone = phone;
}

public Employee getEmployee() {
    return employee;
}

public void setEmployee(Employee employee) {
    this.employee = employee;
}
```

}

12. Fresh Installation Commands

npm install pg
npm run develop

